{
    "version": 2,
    "builds": [{ "src": "index.js", "use": "@vercel/node" }],
    "routes": [{ "src": "/(.*)", "dest": "index.js" }],
    "crons": [
        {
            "path": "/api/cron/overdue-sync",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/payment-reminders",
            "schedule": "0 9 * * *"
        }
    ]
}
