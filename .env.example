JWT_SECRET=change_this_to_a_long_random_string
PORT=5000

# Password reset emails (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FRONTEND_URL=http://localhost:5173

# Production — your Vercel app URL (no trailing slash)
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://www.yourdomain.com
# CORS_ALLOW_VERCEL=true

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
# Optional: set after first server start or create plan in Paystack Dashboard
PAYSTACK_PLAN_CODE=PLN_xxxxxxxx

# Allow Settings "dev premium toggle" to persist plan (local dev only — never true in production)
ALLOW_DEV_PLAN=true
