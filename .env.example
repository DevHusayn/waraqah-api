MONGO_URI=mongodb://localhost:27017/waraqah
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
PORT=5000

# Set to production on live deployments (Vercel sets VERCEL=1 automatically)
# NODE_ENV=production

# --- Transactional email (Resend) ---
# Create an API key at https://resend.com/api-keys
# Domain mywaraqah.com must be verified in Resend before production sends succeed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default sender (must match a verified domain in Resend)
EMAIL_FROM=Waraqah <notifications@mywaraqah.com>

# Optional branding overrides
# EMAIL_SUPPORT=support@mywaraqah.com
# EMAIL_WEBSITE_URL=https://mywaraqah.com
# EMAIL_LOGO_URL=https://mywaraqah.com/logo.png

# Vercel Cron auth — Vercel sends Authorization: Bearer <CRON_SECRET> when invoking cron jobs
CRON_SECRET=change_this_to_a_long_random_string

# Latency: deploy MongoDB Atlas in the same region as your Vercel project (see VERCEL_REGION in logs).
# Example for Nigeria/EU users: choose eu-west-1 (Ireland) or af-south-1 (Cape Town) in Atlas + Vercel.

FRONTEND_URL=http://localhost:5173

# Sign in with Google (optional)
# Google Cloud Console → OAuth 2.0 Client ID (Web). Authorized origins: FRONTEND_URL
GOOGLE_CLIENT_ID=

# Production — exact URL users open in the browser (no trailing slash)
# FRONTEND_URL=https://mywaraqah.com
# API_URL=https://your-api.vercel.app/api
# ALLOWED_ORIGINS=https://www.mywaraqah.com
# CORS_ALLOW_VERCEL=true

# Legacy SMTP (deprecated — use Resend above)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
# Optional: set after first server start or create plan in Paystack Dashboard (₦2,000/month)
# If you change PREMIUM_AMOUNT_NGN, create a new Paystack plan and update this code.
PAYSTACK_PLAN_CODE=PLN_xxxxxxxx

# Allow Settings "dev premium toggle" to persist plan (local dev only — MUST be false in production)
ALLOW_DEV_PLAN=true

# Production requirements (enforced when NODE_ENV=production or VERCEL=1):
# - JWT_SECRET: at least 32 characters
# - MONGO_URI: MongoDB Atlas connection string (mongodb+srv://...)
# - FRONTEND_URL: your live frontend URL
# - RESEND_API_KEY: required for transactional email in production
# - ALLOW_DEV_PLAN=false
